# =========================================================================
# Real-Estate Scraper — Configuration
# Copy to .env and fill in. .env is gitignored.
# =========================================================================

# ----- Notion -----
# 1. Create internal integration at https://www.notion.so/profile/integrations
# 2. Copy the "Internal Integration Secret" (starts with ntn_ or secret_) below
# 3. Open your parent page in Notion → "..." → Connections → add the integration
# 4. Run `python scripts/setup_notion.py` to create the rent DB
#    then paste the returned DB id into NOTION_RENT_DB_ID
NOTION_TOKEN=

# Parent page id (from the page URL you gave — dashes added)
NOTION_PARENT_PAGE_ID=

# Populated by scripts/setup_notion.py after first run
NOTION_RENT_DB_ID=

# ----- Module toggle -----
# Enabled modules this run: rent | buy | sell | rent_for_others (comma-separated)
MODULES_ENABLED=rent

# ----- Sources -----
SOURCE_ZAPIMOVEIS_ENABLED=true
SOURCE_QUINTOANDAR_ENABLED=true

# ----- Search: RENT module -----
RENT_CITY=São Paulo
RENT_STATE=SP
# Neighborhoods in preference order (comma-separated, exact casing matches source normalization)
RENT_NEIGHBORHOODS=Moema,Jardim Paulistano,Jardim Paulista,Vila Nova Conceição,Campo Belo,Brooklin,Itaim Bibi,Vila Olímpia,Pinheiros

# Total monthly price incl. condo + IPTU (BRL)
RENT_PRICE_MIN=4500
RENT_PRICE_MAX=6300

# Unit constraints
RENT_BEDROOMS_MIN=2
RENT_BEDROOMS_MAX=3
RENT_BATHROOMS_MIN=2
RENT_SUITES_MIN=1
RENT_SQM_MIN=70
RENT_PARKING_MIN=1
RENT_PETS_REQUIRED=true

# ----- Work location + distance cap -----
WORK_ADDRESS=Av. Pres. Juscelino Kubitschek, 1830 - Itaim Bibi, São Paulo - SP, 04543-900
WORK_MAX_DISTANCE_KM=5.5
# Optional override (skip geocoding if set)
WORK_LAT=
WORK_LNG=

# ----- Schedule -----
# Cron expressions (one per run time, comma-separated); default = 2×/day 09:00 + 18:00 BRT
SCHEDULE_CRON_TIMES=0 9 * * *,0 18 * * *
SCHEDULE_TZ=America/Sao_Paulo

# ----- HTTP + anti-bot -----
HTTP_IMPERSONATE=chrome124
HTTP_MIN_DELAY_SEC=3
HTTP_MAX_DELAY_SEC=10
HTTP_MAX_RETRIES=5
HTTP_BACKOFF_BASE_SEC=1
# Playwright fallback if HTTP gets 403 repeatedly
HTTP_PLAYWRIGHT_FALLBACK=true

# User-Agent rotation pool (| separated). Leave blank to use curl-cffi default.
HTTP_USER_AGENTS=

# ----- Geocoding -----
GEOCODER_USER_AGENT=real-estate-scraper/0.1 
GEOCODER_RATE_LIMIT_SEC=1

# ----- Logging -----
LOG_LEVEL=INFO
LOG_DIR=logs

# ----- Cache -----
CACHE_DIR=.cache

# ----- Search: BUY module -----
# All filters configurable independently from RENT_*.
# BUY_NEIGHBORHOODS falls back to RENT_NEIGHBORHOODS if blank.
BUY_CITY=São Paulo
BUY_STATE=SP
BUY_NEIGHBORHOODS=
BUY_PRICE_MIN=500000
BUY_PRICE_MAX=1200000
# Max monthly condominium fee in BRL (0 = no cap; applied post-fetch)
BUY_CONDO_MAX=0
BUY_BEDROOMS_MIN=2
BUY_BEDROOMS_MAX=3
BUY_BATHROOMS_MIN=2
BUY_SUITES_MIN=1
BUY_SQM_MIN=70
BUY_PARKING_MIN=1
# Property types: apartment,house,condo_house (or blank for any)
BUY_PROPERTY_TYPES=
BUY_PETS_REQUIRED=false
BUY_FURNISHED_ALLOWED=true

# ----- Notion: BUY module -----
# Populated by: uv run python scripts/setup_notion.py --kind buy
NOTION_BUY_DB_ID=

# ----- Sources: BUY module -----
SOURCE_ZAPIMOVEIS_BUY_ENABLED=true
SOURCE_QUINTOANDAR_BUY_ENABLED=false
